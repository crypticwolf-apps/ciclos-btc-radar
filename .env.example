# =============================================================================
# Copia este archivo a `.env` y rellena las claves que tengas. NINGUNA clave
# lleva prefijo VITE_: todas se usan SOLO en el backend (/api/*) y nunca se
# exponen al navegador. Sin una clave, su módulo se muestra como "bloqueado".
# =============================================================================

# --- Macro (FRED) · gratis ---------------------------------------------------
# Necesaria para el bloque macro (tipos, CPI, paro, treasuries, dólar, M2,
# S&P 500, VIX). Se obtiene gratis en https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# --- CoinGecko · opcional ----------------------------------------------------
# Clave demo gratuita: sube el límite de peticiones y reduce errores 429.
# https://www.coingecko.com/api  (plan "Demo")
COINGECKO_API_KEY=

# --- On-chain premium · opcional (de pago) -----------------------------------
# Sin estas claves, las métricas premium (MVRV, SOPR, Puell, LTH/STH, ETF…)
# aparecen como tarjeta bloqueada.
GLASSNODE_API_KEY=
DUNE_API_KEY=
DUNE_QUERY_ID=

# --- Nodo Bitcoin propio · opcional ------------------------------------------
# Si tienes un nodo, se usará para altura de bloque / info de red vía RPC.
BITCOIN_RPC_URL=
BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=

# --- Cache compartida (Upstash Redis) · opcional -----------------------------
# Recomendada en producción serverless para que cache y rate limit persistan
# entre invocaciones. Sin ella se usa cache en memoria por instancia.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Front (opcional) --------------------------------------------------------
# Base de la API interna si el backend vive en otro origen. Por defecto "" (mismo
# origen, p. ej. /api/* en Vercel).
# VITE_API_BASE=
